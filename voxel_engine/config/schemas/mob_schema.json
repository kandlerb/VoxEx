{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Mob Definition",
  "description": "Core mob stats - separate from AI and spawn conditions",
  "type": "object",
  "required": ["id", "name", "type", "health"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "type": { "type": "string", "enum": ["hostile", "passive", "neutral"] },
    "health": { "type": "integer", "minimum": 1 },
    "max_health": { "type": "integer", "minimum": 1 },
    "movement": {
      "type": "object",
      "properties": {
        "walk_speed": { "type": "number" },
        "chase_speed": { "type": "number" },
        "sidestep_speed": { "type": "number" },
        "jump_force": { "type": "number" }
      }
    },
    "combat": {
      "type": "object",
      "properties": {
        "attack_range": { "type": "number" },
        "attack_cooldown": { "type": "number" },
        "attack_damage": { "type": "integer" }
      }
    },
    "collision": {
      "type": "object",
      "properties": {
        "radius": { "type": "number" },
        "half_width": { "type": "number" },
        "height": { "type": "number" }
      }
    }
  }
}
