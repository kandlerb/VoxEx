{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Texture Generation Config",
    "description": "Defines how to procedurally generate a block texture",
    "type": "object",
    "properties": {
        "type": {
            "type": "string",
            "enum": ["noise_fill", "layered", "log_bark", "log_rings", "sparse", "gradient", "planks", "shape", "reference"],
            "description": "The generation algorithm to use"
        },
        "seed_offset": {
            "type": "integer",
            "description": "Added to tile index for seeded RNG (for determinism)"
        },
        "allow_transparency": {
            "type": "boolean",
            "default": false,
            "description": "Whether this texture can have transparent pixels"
        },
        "palette": {
            "type": "object",
            "description": "Named colors used by this texture",
            "additionalProperties": {
                "oneOf": [
                    {"type": "string", "pattern": "^#[0-9a-fA-F]{6}$"},
                    {"type": "array", "items": {"type": "string", "pattern": "^#[0-9a-fA-F]{6}$"}}
                ]
            }
        },
        "params": {
            "type": "object",
            "description": "Algorithm-specific parameters"
        }
    },
    "required": ["type"]
}
